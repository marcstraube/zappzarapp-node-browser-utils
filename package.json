{
  "name": "@zappzarapp/browser-utils",
  "version": "1.2.0",
  "description": "Comprehensive browser utilities: storage, cookies, clipboard, keyboard shortcuts, forms, observers, network retry, and more. Type-safe, tree-shakeable, zero dependencies.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js"
    },
    "./download": {
      "types": "./dist/download/index.d.ts",
      "import": "./dist/download/index.js"
    },
    "./keyboard": {
      "types": "./dist/keyboard/index.d.ts",
      "import": "./dist/keyboard/index.js"
    },
    "./html": {
      "types": "./dist/html/index.d.ts",
      "import": "./dist/html/index.js"
    },
    "./cookie": {
      "types": "./dist/cookie/index.d.ts",
      "import": "./dist/cookie/index.js"
    },
    "./clipboard": {
      "types": "./dist/clipboard/index.d.ts",
      "import": "./dist/clipboard/index.js"
    },
    "./url": {
      "types": "./dist/url/index.d.ts",
      "import": "./dist/url/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./features": {
      "types": "./dist/features/index.d.ts",
      "import": "./dist/features/index.js"
    },
    "./network": {
      "types": "./dist/network/index.d.ts",
      "import": "./dist/network/index.js"
    },
    "./focus": {
      "types": "./dist/focus/index.d.ts",
      "import": "./dist/focus/index.js"
    },
    "./scroll": {
      "types": "./dist/scroll/index.d.ts",
      "import": "./dist/scroll/index.js"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "import": "./dist/form/index.js"
    },
    "./fullscreen": {
      "types": "./dist/fullscreen/index.d.ts",
      "import": "./dist/fullscreen/index.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js"
    },
    "./notification": {
      "types": "./dist/notification/index.d.ts",
      "import": "./dist/notification/index.js"
    },
    "./device": {
      "types": "./dist/device/index.d.ts",
      "import": "./dist/device/index.js"
    },
    "./observe": {
      "types": "./dist/observe/index.d.ts",
      "import": "./dist/observe/index.js"
    },
    "./idle": {
      "types": "./dist/idle/index.d.ts",
      "import": "./dist/idle/index.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize/index.d.ts",
      "import": "./dist/sanitize/index.js"
    },
    "./indexeddb": {
      "types": "./dist/indexeddb/index.d.ts",
      "import": "./dist/indexeddb/index.js"
    },
    "./websocket": {
      "types": "./dist/websocket/index.d.ts",
