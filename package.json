  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "lint:secrets": "secretlint '**/*'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '**/*.json' '**/*.md' '!node_modules/**' '!dist/**' '!coverage/**' '!pnpm-lock.yaml' '!CHANGELOG.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '**/*.json' '**/*.md' '!node_modules/**' '!dist/**' '!coverage/**' '!pnpm-lock.yaml' '!CHANGELOG.md'",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "mutation": "stryker run",
    "sbom": "cdxgen -t js -o sbom.cdx.json --spec-version 1.5 --no-recurse --no-babel",
    "docs": "typedoc",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run size:check && pnpm audit --prod --audit-level=moderate",
    "prepare": "husky || true"
  },
  "keywords": [
    "browser",
    "utilities",
    "typescript",
    "localStorage",
    "sessionStorage",
    "cookies",
    "clipboard",
    "keyboard-shortcuts",
    "form-validation",
    "intersection-observer",
    "resize-observer",
    "mutation-observer",
    "idle-callback",
    "network-retry",
    "debounce",
    "throttle",
    "fullscreen",
    "notifications",
    "media-queries",
    "focus-trap",
    "scroll-lock",
    "tree-shakeable",
    "zero-dependencies"
  ],
  "author": "Marc Straube <email@marcstraube.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcstraube/zappzarapp-node-browser-utils.git"
  },
  "bugs": {
    "url": "https://github.com/marcstraube/zappzarapp-node-browser-utils/issues"
  },
  "homepage": "https://github.com/marcstraube/zappzarapp-node-browser-utils#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@cyclonedx/cdxgen": "^12.0.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.2.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsdoc": "^62.5.4",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.3.0",
    "happy-dom": "^20.6.1",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.0.0",
    "secretlint": "^11.3.1",
    "size-limit": "^12.0.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "dompurify": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "dompurify": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
