    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/performance/index.js"
    },
    "./broadcast": {
      "types": "./dist/broadcast/index.d.ts",
      "import": "./dist/broadcast/index.js"
    },
    "./offline": {
      "types": "./dist/offline/index.d.ts",
      "import": "./dist/offline/index.js"
    },
    "./request": {
      "types": "./dist/request/index.d.ts",
      "import": "./dist/request/index.js"
    },
    "./encryption": {
