{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend",
      "rules": [
        {
          "id": "@secretlint/secretlint-rule-basicauth",
          "allowMessageIds": [],
          "options": {
            "allows": ["/user:pass@example\\.com/", "/page=1&limit=10/"]
          }
        }
      ],
      "options": {
        "allows": [
          "/example\\.com/",
          "/localhost/",
          "/127\\.0\\.0\\.1/",
          "/your-secret-key/",
          "/my-secure-password/",
          "/test-.*-key/"
        ]
      }
    }
  ]
}
